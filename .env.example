# Database
DATABASE_URL=postgresql://cenaei:password@localhost:5432/cenaei

# Redis (sessions / rate limits — wire in app when needed)
REDIS_URL=redis://localhost:6379

# Better Auth (@cenaei/web)
BETTER_AUTH_SECRET=change-me-min-32-characters-secret
BETTER_AUTH_URL=http://localhost:3000

# Subdomain rewrites (main Next app middleware → internal URLs in Docker)
GAMES_APP_URL=http://localhost:3001
DEMOS_APP_URL=http://localhost:3002
TOOLS_APP_URL=http://localhost:3003

# Demos reverse proxy upstream
DEMO_PROXY_BASE=http://localhost:8080

# TLS / ops
ACME_EMAIL=you@example.com
POSTGRES_PASSWORD=change-me
